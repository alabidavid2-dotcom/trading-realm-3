# Environment variables — NEVER commit real credentials
.env*
.streamlit/secrets.toml

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
venv/
.venv/
env/

# Jupyter
.ipynb_checkpoints/

# OS
.DS_Store
Thumbs.db

# Runtime logs (Streamlit / subprocess output)
run_*.txt
sl_*.txt
streamlit_*.txt
*.base64.txt

# Runtime data files (regenerated at runtime)
scan_history.json
pnl_history.json
tracker_data.json
alerts_log.json
universe.json

# ML model artifacts — WARNING: models/hmm_model.pkl (1.7KB) must be
# force-committed before deploying to Streamlit Community Cloud:
#   git add -f models/hmm_model.pkl
# Streamlit Cloud has no post-deploy training step; without it the
# regime engine crashes on every scan.
models/*.pkl

# Editor / tool directories
.vscode/
.claude/
